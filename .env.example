# Resend email API — https://resend.com
# Sign up and create an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# FROM_EMAIL must be a verified Resend sender address.
# Use "onboarding@resend.dev" for testing (free plan).
# For production, verify your own domain and use e.g. "contact@yourdomain.com".
FROM_EMAIL=onboarding@resend.dev

# TO_EMAIL is where contact form messages are delivered (your personal inbox).
# If omitted, defaults to FROM_EMAIL.
TO_EMAIL=your-email@gmail.com
